<!DOCTYPE html>
<html>

<head>
    <meta charset="UTF-8" />
    <title>Reset Your Password - Skill Barter</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #f3f4f6;
            font-family: Arial, Helvetica, sans-serif;
        }

        .wrapper {
            width: 100%;
            padding: 40px 0;
        }

        .container {
            width: 100%;
            max-width: 600px;
            margin: auto;
            background-color: #ffffff;
            border-radius: 10px;
            overflow: hidden;
            box-shadow: 0 6px 18px rgba(0, 0, 0, 0.06);
        }

        .header {
            background: linear-gradient(135deg, #4f46e5, #6366f1);
            padding: 30px 20px;
            text-align: center;
            color: #ffffff;
        }

        .header h1 {
            margin: 0;
            font-size: 22px;
            letter-spacing: 1px;
        }

        .content {
            padding: 35px 30px;
            text-align: center;
            color: #333333;
        }

        .content h2 {
            margin-top: 0;
            font-size: 20px;
            color: #111827;
        }

        .content p {
            font-size: 14px;
            line-height: 1.7;
            color: #555555;
        }

        .button-container {
            margin: 30px 0;
        }

        .reset-btn {
            display: inline-block;
            padding: 14px 28px;
            background-color: #4f46e5;
            color: #ffffff !important;
            text-decoration: none;
            font-size: 14px;
            font-weight: bold;
            border-radius: 6px;
        }

        .reset-btn:hover {
            background-color: #4338ca;
        }

        .link-box {
            word-break: break-all;
            background-color: #f9fafb;
            padding: 12px;
            border-radius: 6px;
            font-size: 12px;
            color: #6b7280;
            margin-top: 15px;
        }

        .footer {
            background-color: #f9fafb;
            padding: 20px;
            text-align: center;
            font-size: 12px;
            color: #888888;
        }

        .divider {
            height: 1px;
            background-color: #e5e7eb;
            margin: 20px 0;
        }

        @media screen and (max-width: 600px) {
            .container {
                margin: 0 15px;
            }

            .content {
                padding: 25px 20px;
            }

            .reset-btn {
                width: 100%;
                display: block;
            }
        }
    </style>
</head>

<body>

    <div class="wrapper">
        <div class="container">

            <div class="header">
                <h1>Skill Barter</h1>
            </div>

            <div class="content">
                <h2>Password Reset Request</h2>

                <p>
                    Hello <strong>
                        <%= name %>
                    </strong>,
                </p>

                <p>
                    We received a request to reset the password for your Skill Barter account associated with:
                </p>

                <p><strong>
                        <%= email %>
                    </strong></p>

                <div class="divider"></div>

                <p>
                    Click the button below to reset your password.
                    This link will expire in <strong>5 minutes</strong>.
                </p>

                <div class="button-container">
                    <a href="<%= resetLink %>" class="reset-btn">
                        Reset Password
                    </a>
                </div>

                <p>If the button does not work, copy and paste the link below into your browser:</p>

                <div class="link-box">
                    <%= resetLink %>
                </div>

                <div class="divider"></div>

                <p>
                    If you did not request this password reset, you can safely ignore this email.
                    Your account will remain secure.
                </p>
            </div>

            <div class="footer">
                © <%= new Date().getFullYear() %> Skill Barter. All rights reserved.
            </div>

        </div>
    </div>

</body>

</html>